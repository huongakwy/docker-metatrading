# MT5 Docker Cluster Configuration
# Copy to .env and fill in your values

# Port base cho cac instance (se tu dong tang)
VNC_PORT_BASE=3000
RPC_PORT_BASE=8001

# User/Password cho MT5
CUSTOM_USER=admin
PASSWORD=123

# Timezone
TZ=Asia/Ho_Chi_Minh

# Tat VNC de tiet kiem RAM/CPU
NOVNC=true

# UID/GID
PUID=1000
PGID=1000

# So luong instance mac dinh
DEFAULT_REPLICAS=2

# Number of MT5 instances (default: 5)
NUM_INSTANCES=5

# Docker image
DOCKER_IMAGE=gmag11/metatrader5_vnc:1.0

# Network
MT5_NETWORK=mt5-network

# ============================================================================
# MT5 Account Configuration
# ============================================================================
# MT5 login credentials (will be used in startup.ini)
# Replace with your actual MT5 account details
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server

# EA Configuration
# EA name without .ex5 extension
EA_NAME=TradingBridgeeaV2
# Trading symbol
EA_SYMBOL=XAUUSDm
# Timeframe: M1, M5, M15, M30, H1, H4, D1, W1, MN
EA_TIMEFRAME=M1
# Chart template name (with .tpl extension)
EA_TEMPLATE=AutoBridge.tpl

# Optional: Docker registry credentials if using private registry
# DOCKER_REGISTRY_USER=
# DOCKER_REGISTRY_PASS=
